# deploy/docker-compose/clio.env  (nach clio.env kopieren, Werte anpassen)
# Profil "small-production" (siehe docs/operations-profiles.md).

CLIO_DB_PATH=/data/clio.db
CLIO_SYNC=group
CLIO_QUERY_TIMEOUT=15s
CLIO_DB_INITIAL_MB=1024
CLIO_DB_GROW_THRESHOLD_PCT=80
CLIO_DB_COMPACT_ENABLED=true
CLIO_DB_COMPACT_INTERVAL_H=24

# Erststart-Bootstrap: einmalig setzen, danach entfernen und Container neu starten.
# CLIO_BOOTSTRAP_ADMIN_KEY=ein-langes-zufaelliges-geheimnis

# Token für das backup-Profil (Scope admin). Nach Erststart anlegen:
#   POST /api/v1/keys {"name":"backup","scopes":["admin"]}
# CLIO_BACKUP_TOKEN=kid_xxx.secret

# CLIO_SIGNING_KEY=base64-seed     # optional: Event-Signaturen
# CLIO_DEV_MODE=true               # NIEMALS in Produktion
