# /etc/clio/clio.env  (chmod 600, gehört root)
#
# Konfiguration für cliostore.service. Werte hier sind das Profil
# "small-production" (siehe docs/operations-profiles.md). Zeilen anpassen/
# auskommentieren nach Bedarf.

# Nur lokal lauschen; TLS/öffentlicher Zugang über Reverse Proxy.
CLIO_ADDR=127.0.0.1:3000

# Datenbankdatei im StateDirectory (DynamicUser/StateDirectory => /var/lib/clio).
CLIO_DB_PATH=/var/lib/clio/clio.db

# Durability: group = voll durabel bei hohem Durchsatz (Default). always | off möglich.
CLIO_SYNC=group

# Breite Scans begrenzen (Default AUS — in Produktion setzen!).
CLIO_QUERY_TIMEOUT=15s

# Mmap vorbelegen -> keine Remap-Latenzspitzen; Headroom-Warnung bei 80 %.
CLIO_DB_INITIAL_MB=1024
CLIO_DB_GROW_THRESHOLD_PCT=80

# Online-Compaction periodisch (kurze Downtime pro Lauf) — ruhiges Fenster wählen.
CLIO_DB_COMPACT_ENABLED=true
CLIO_DB_COMPACT_INTERVAL_H=24

# Optional: Event-Signaturen (Ed25519). Mit `cliostore gen-key` erzeugen.
# CLIO_SIGNING_KEY=base64-seed

# Auth-Bootstrap: NUR für den allerersten Start setzen, danach Zeile entfernen
# und neu starten (ADR-025). Erzeugt einen Admin-Key; der kid steht im Startlog.
# CLIO_BOOTSTRAP_ADMIN_KEY=ein-langes-zufaelliges-geheimnis

# NIEMALS in Produktion:
# CLIO_DEV_MODE=true
